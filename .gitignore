# Python & Jupyter
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/

# Virtual Environments
venv/
env/
.env

# Data & Large outputs (Avoid committing huge log files or raw datasets)
data/
results/*.json
results/*.txt
results/*.pt

# Note: We EXCLUDE the ignore for images so you can show them in README
!results/*.png
!results/*.jpg